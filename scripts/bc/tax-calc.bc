#!/bin/sh
# scripts/bc/tax-calc.bc — Compute 10% GST on a subtotal
# Usage: bc -q scripts/bc/tax-calc.bc <<< "SUBTOTAL"
# Example: echo "100" | bc -q scripts/bc/tax-calc.bc  -> 110.00
# SELF-TEST: echo "100" | bc -q scripts/bc/tax-calc.bc  -> 110.00
# SELF-TEST: echo "14"  | bc -q scripts/bc/tax-calc.bc  -> 15.40
# SELF-TEST: echo "39"  | bc -q scripts/bc/tax-calc.bc  -> 42.90

scale = 2

subtotal = 0
while (read line) {
    subtotal = 0 + line
}

subtotal * 1.10
