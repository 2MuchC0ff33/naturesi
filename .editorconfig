root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.sh]
indent_style = tab
insert_final_newline = true

[*.awk]
indent_style = tab
insert_final_newline = true

[*.bc]
indent_style = tab
insert_final_newline = true

[*.sed]
indent_style = tab
insert_final_newline = true

[*.json]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.html]
indent_size = 2
insert_final_newline = true

[*.md,*.markdown]
trim_trailing_whitespace = false

[*.js]
indent_size = 2
insert_final_newline = true

[*.css]
indent_size = 2
insert_final_newline = true

[*.env]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.c,*.h]
insert_final_newline = true

[*.f,*.for]
indent_size = 2
insert_final_newline = true

[*.l]
insert_final_newline = true

[*.s,*.asm]
indent_style = tab
indent_size = 8
insert_final_newline = true

[*.m4]
insert_final_newline = true

[*.y]
insert_final_newline = true

[*.xml]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.yml]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# PHP files: common 4-space indent
[*.php]
indent_style = space
indent_size = 4
insert_final_newline = true

# Perl scripts/modules
[*.pl]
indent_style = space
indent_size = 4
insert_final_newline = true

[*.pm]
indent_style = space
indent_size = 4
insert_final_newline = true

[*.t]
indent_style = space
indent_size = 4
insert_final_newline = true

# SQL
[*.sql]
indent_style = space
indent_size = 2
insert_final_newline = true

# AssemblyScript extensions (treated as TypeScript)
[*.asc]
indent_style = space
indent_size = 2
insert_final_newline = true

[*.csv]
trim_trailing_whitespace = true
insert_final_newline = true

[*.tsv]
trim_trailing_whitespace = true
insert_final_newline = true

[*.{png,jpg,jpeg,gif,ico,svg,webp,zip,gz,7z}]
binary = true
