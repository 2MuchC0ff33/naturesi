# EditorConfig helps maintain consistent coding styles between editors
root = true

[ * ]
# Use UTF-8 for all files
charset = utf-8
# Use LF for all line endings
end_of_line = lf
# Insert final newline at end of file
insert_final_newline = true
# Trim trailing whitespace by default
trim_trailing_whitespace = true

[*.md]
# Keep trailing whitespace in markdown files (often used for hard line breaks)
trim_trailing_whitespace = false

[*.{png,jpg,jpeg,gif,ico,svg,webp,zip,gz,7z}]
binary = true
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
