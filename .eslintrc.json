{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": ["eslint:recommended", "plugin:prettier/recommended"],
  "parser": "@babel/eslint-parser",
  "parserOptions": {
    "requireConfigFile": false,
    "babelOptions": {
      "presets": ["@babel/preset-env"],
      "plugins": ["@babel/plugin-syntax-import-assertions"]
    },
    "ecmaVersion": 13,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off"
  },
  "plugins": ["html"],
  "overrides": [
    {
      "files": ["*.html"],
      "parser": "espree",
      "rules": {
        // Add specific rules for HTML here
      }
    }
  ]
}
