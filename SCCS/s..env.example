# .env.example for Ultra-Simple  Static EStore Framework
# Copy to .env and fill in actual values for deployment

# Site/Business Info
SITE_NAME=Ultra-Simple  EStore
SITE_URL=https://www.naturesinfusions.com.au
BUSINESS_EMAIL=info@naturesinfusions.com.au
PAYPAL_EMAIL=your-paypal@example.com

# Branding
PRIMARY_COLOR=#009688
SECONDARY_COLOR=#ffffff
ACCENT_COLOR=#ff9800
LOGO_PATH=assets/img/logo.svg

# Product/CSV Data
PRODUCTS_CSV_PATH=data/products.csv
STOCKISTS_CSV_PATH=data/stockists.csv

# Hosting/Deployment
DEPLOY_PATH=/var/www/naturesinfusions.com.au/
MAX_BUNDLE_SIZE_MB=2

# Security
ALLOWED_ORIGIN=https://www.naturesinfusions.com.au
CSP_HEADER=default-src 'self'; img-src 'self' data:; script-src 'self'; style-src 'self';
ENABLE_HTTPS=true

# Accessibility
WCAG_LEVEL=AA
ACCESSIBILITY_AUDIT=true

# Support
SUPPORT_EMAIL=support@naturesinfusions.com.au
SUPPORT_TICKET_FORM=mailto:support@naturesinfusions.com.au

# Analytics (optional)
ENABLE_ANALYTICS=false
ANALYTICS_ID=

# SEO/Verification
GOOGLE_SITE_VERIFICATION=your-google-site-verification-code
BING_SITE_VERIFICATION=your-bing-site-verification-code
YANDEX_SITE_VERIFICATION=your-yandex-site-verification-code

# Service Worker
ENABLE_SERVICE_WORKER=true

# Miscellaneous
PAYPAL_ENV = sandbox | live

# PayPal Sandbox
PAYPAL_SANDBOX_BUYER_EMAIL=your-sandbox-buyer-email@example.com
PAYPAL_SANDBOX_BUYER_PASSWORD=your-sandbox-buyer-password
PAYPAL_SANDBOX_MERCHANT_EMAIL=your-sandbox-merchant-email@example.com
PAYPAL_SANDBOX_MERCHANT_PASSWORD=your-sandbox-merchant-password
PAYPAL_SANDBOX_CLIENT_ID=YOUR_SANDBOX_CLIENT_ID
PAYPAL_SANDBOX_SECRET_KEY=YOUR_SANDBOX_SECRET_KEY

# Additional Personal Account Details
PAYPAL_SANDBOX_BUYER_NAME=Your Sandbox Buyer Name
PAYPAL_SANDBOX_BUYER_PHONE=your-sandbox-buyer-phone
PAYPAL_SANDBOX_BUYER_COUNTRY=AU
PAYPAL_SANDBOX_BUYER_ACCOUNT_TYPE=Personal
PAYPAL_SANDBOX_BUYER_ACCOUNT_ID=YOUR_SANDBOX_BUYER_ACCOUNT_ID
PAYPAL_SANDBOX_BUYER_STATUS=Verified
PAYPAL_SANDBOX_BUYER_CREDIT_CARDS=1 added
PAYPAL_SANDBOX_BUYER_BANKS=1 of 4 added
PAYPAL_SANDBOX_BUYER_BALANCE=AUD 5,000

# Credit Card Details
PAYPAL_SANDBOX_BUYER_CC_TYPE=VISA
PAYPAL_SANDBOX_BUYER_CC_NUMBER=YOUR_SANDBOX_CC_NUMBER
PAYPAL_SANDBOX_BUYER_CC_EXPIRY=11/2030
PAYPAL_SANDBOX_BUYER_CC_CVC=Any 3 digits

# Fastlane Eligible VISA Credit Card (Personal Sandbox)
PAYPAL_SANDBOX_BUYER_FASTLANE_CC_TYPE=VISA
PAYPAL_SANDBOX_BUYER_FASTLANE_CC_NUMBER=YOUR_SANDBOX_FASTLANE_CC_NUMBER
PAYPAL_SANDBOX_BUYER_FASTLANE_CC_EXPIRY=MM/YYYY
PAYPAL_SANDBOX_BUYER_FASTLANE_CC_CVC=YOUR_SANDBOX_FASTLANE_CC_CVC

# Bank Details
PAYPAL_SANDBOX_BUYER_BANK_TYPE=Checking
PAYPAL_SANDBOX_BUYER_BANK_ACCOUNT=YOUR_SANDBOX_BANK_ACCOUNT
PAYPAL_SANDBOX_BUYER_BANK_ROUTING=YOUR_SANDBOX_BANK_ROUTING

# PayPal Live
PAYPAL_LIVE_APP_NAME=Your Live App Name
PAYPAL_LIVE_CLIENT_ID=YOUR_LIVE_CLIENT_ID
PAYPAL_LIVE_SECRET_KEY=YOUR_LIVE_SECRET_KEY
PAYPAL_BUSINESS_EMAIL=YOUR_BUSINESS_EMAIL
PAYPAL_RETURN_URL=https://www.yoursite.com/return
PAYPAL_RETURN_URL_CANCEL=https://www.yoursite.com/cancel

# PayPal Configuration Notes
PAYPAL_SANDBOX_APP_NAME=Default Application
PAYPAL_WEBHOOKS_SETUP=false

# PayPal Sandbox REST API App
PAYPAL_SANDBOX_REST_APP_NAME=Default Application
PAYPAL_SANDBOX_REST_CLIENT_ID=YOUR_SANDBOX_REST_CLIENT_ID
PAYPAL_SANDBOX_REST_SECRET=YOUR_SANDBOX_REST_SECRET
