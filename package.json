  "homepage": "https://github.com/2MuchC0ff33/naturesi#readme",
  "devDependencies": {
    "@playwright/test": "^1.38.0",
    "playwright": "^1.38.0",
    "vitest": "^0.30.0",
    "jsdom": "^21.0.0",
    "axe-core": "^4.7.0",
    "axe-playwright": "^2.0.0",
    "pa11y": "^6.0.0",
    "lighthouse": "^9.6.0",
    "jest-image-snapshot": "^4.0.0",
    "pixelmatch": "^5.3.0",
    "http-server": "^14.1.1",
    "speedline": "^1.3.0",
    "fake-indexeddb": "^3.1.7",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1"
  },
  "scripts": {
    "start:static": "npx http-server -c-1 -p 8080 .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest --watch",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:headed": "PWDEBUG=1 playwright test --headed",
    "test:e2e:debug": "PWDEBUG=1 playwright test --project=chromium --debug",
    "test:a11y": "playwright test --grep @a11y",
    "test:visual": "playwright test --project=chromium --grep @visual",
    "test:perf": "mkdir -p reports && lighthouse http://127.0.0.1:8080/index.html --output=json --output-path=./reports/lighthouse-index.json --chrome-flags=\"--headless\" && lighthouse http://127.0.0.1:8080/pages/checkout.html --output=json --output-path=./reports/lighthouse-checkout.json --chrome-flags=\"--headless\"",
    "test:security": "npm run audit && semgrep --config=auto",
    "audit": "npm audit --audit-level=high",
    "generate-paypal-config": "node scripts/generate-paypal-config.js",
    "prestart:static": "node scripts/generate-paypal-config.js",
    "test": "npm run test:unit && npm run test:e2e && npm run test:perf",
    "format": "npx prettier --write ."
  },
  "dependencies": {}
}
