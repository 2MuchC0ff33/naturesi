{
  "name": "naturesi",
  "version": "1.0.0",
  "type": "module",
  "description": "Nature's Infusions static e-commerce site",
  "author": "2MuchC0ff33",
  "scripts": {
    "build:css": "sass assets/css/main.scss assets/css/output.css && postcss assets/css/output.css -o public/assets/css/main.css && node tests/check_css_build.cjs",
    "watch:css": "pnpm exec concurrently --kill-others \"sass --watch assets/css/main.scss:assets/css/output.css\" \"postcss --watch assets/css/output.css -o public/assets/css/main.css\"",
    "verify:css": "node tests/check_css_build.cjs",
    "build:ts": "tsc"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead"
  ],
  "dependencies": {
    "assemblyscript": "^0.28.9",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "postcss-import": "^15.1.0",
    "stylelint": "^17.4.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@picocss/pico": "^2.1.1",
    "concurrently": "^8.2.2",
    "open-props": "^1.7.23",
    "postcss-cli": "^11.0.1",
    "sass": "^1.97.3"
  }
}
