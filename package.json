  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "prepare": "husky install",
    "stylelint": "stylelint \"**/*.{css,scss}\" --fix",
    "lint": "eslint \"**/*.js\" --fix",
    "generate:categories": "node scripts/generate-product-categories.js",
    "refactor:postcodes": "node scripts/refactor-postcodes.js",
    "serve": "python -m http.server 8000",
    "pa11y": "node scripts/run-pa11y.js"
  },
  "lint-staged": {
    "*.{css,scss}": [
      "prettier --write",
      "stylelint --fix",
      "git add"
    ],
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ],
    "*.{html,md,json}": [
      "prettier --write",
      "git add"
