# Ultra-Simple  Static EStore Framework – .htaccess
# Standards: Mobile-First, Accessibility, Security

# --- Security Headers ---
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.paypal.com https://www.sandbox.paypal.com https://www.paypalobjects.com; script-src-elem 'self' 'sha256-QwXwNPh43Mi79vmf0GEgGOOqdsubXLdpx8U/GiCdfi8=' 'sha256-KVay2l692L/3HwaaamuyeyVtGH+R0rjPC/eUdEW9aKI=' 'unsafe-inline' https://www.paypal.com https://www.sandbox.paypal.com https://www.paypalobjects.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://www.paypal.com https://www.sandbox.paypal.com https://www.paypalobjects.com; form-action 'self' https://www.paypal.com https://www.sandbox.paypal.com mailto:; upgrade-insecure-requests;"
  # Additional security headers (enable when ready)
  # Permissions-Policy restricts device features (adjust as needed)
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # HSTS: enabled for production WITH preload. Ensure all subdomains and hosts serve HTTPS, then submit to https://hstspreload.org
  # Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  # Expect-CT is optional; configure report-uri or remove if not used
  # Header always set Expect-CT "max-age=86400, enforce, report-uri=\"https://example.com/report\""
</IfModule>

# --- MIME Types for SVG, WebP, CSS, PNG, ICO ---
AddType text/html .html
AddType image/svg+xml .svg
AddType image/webp .webp
AddType text/css .css
AddType image/png .png
AddType image/x-icon .ico

# --- Gzip Compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# --- Disable All Caching for Development ---
<IfModule mod_expires.c>
  ExpiresActive On
  # Disable caching for all file types
  ExpiresByType image/webp "access plus 0 seconds"
  ExpiresByType image/png "access plus 0 seconds"
  ExpiresByType image/svg+xml "access plus 0 seconds"
  ExpiresByType image/x-icon "access plus 0 seconds"
  ExpiresByType image/jpeg "access plus 0 seconds"
  ExpiresByType image/gif "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType application/json "access plus 0 seconds"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/plain "access plus 0 seconds"
  ExpiresByType text/xml "access plus 0 seconds"
</IfModule>

# --- PRODUCTION: Example long-lived caching (enable when you use cache-busting for assets) ---
# Uncomment and adjust when moving to production
# <IfModule mod_expires.c>
#   ExpiresActive On
#   ExpiresByType text/css "access plus 1 year"
#   ExpiresByType application/javascript "access plus 1 year"
#   ExpiresByType image/webp "access plus 1 year"
#   ExpiresByType image/png "access plus 1 year"
#   Header set Cache-Control "public, max-age=31536000, immutable"
# </IfModule>
# --- End Production cache example ---

# --- Production Cache Control ---
<IfModule mod_headers.c>
  # Static assets: long-lived caching (ensure cache-busting on deploys)
  <FilesMatch "\.(css|js|svg|png|jpe?g|gif|webp|ico|woff2?|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML and JSON: short cache to allow content updates and revalidation
  <FilesMatch "\.(html|json)$">
    Header set Cache-Control "public, max-age=60, must-revalidate"
  </FilesMatch>

  # Cloudflare caching is best configured in the Cloudflare dashboard. Remove
  # development-specific Cloudflare bypass headers to allow proper edge caching.
</IfModule>

# --- Custom 404 Page ---
ErrorDocument 404 /404.html

# --- Clean URLs: Redirect index.html and fallback ---
RewriteEngine On
DirectoryIndex index.html

# --- Force HTTPS (handles proxies like Cloudflare) ---
# Only enable when site is served over HTTPS on all hostnames (including www)
# Checks both direct HTTPS and X-Forwarded-Proto (used by proxies/CDNs)
RewriteCond %{HTTP_HOST} !^localhost
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect /index.html to /
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Fallback to index.html for non-file requests (SPA-like)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.html [L]

# --- Disable Directory Listing ---
Options -Indexes +FollowSymLinks

# --- Crossdomain.xml and robots.txt ---
<IfModule mod_headers.c>
  <FilesMatch "^(crossdomain\.xml|robots\.txt)$">
    Header set Content-Type text/xml
  </FilesMatch>
</IfModule>

# --- Prevent access to hidden files ---
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# --- CORS for manifest.json ---
<IfModule mod_headers.c>
  <Files "manifest.json">
    Header set Access-Control-Allow-Origin "*"
  </Files>
</IfModule>

# --- CORS for static assets (CSS, images, SVG, ICO, etc) ---
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|svg|png|jpe?g|gif|ico|webp)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# --- End of .htaccess ---
