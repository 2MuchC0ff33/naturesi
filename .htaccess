# Ultra-Simple Static EStore Framework – .htaccess
# Standards: Mobile-First, Accessibility, Security

# --- Security Headers ---
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.paypal.com https://www.sandbox.paypal.com https://www.paypalobjects.com; script-src-elem 'self' 'unsafe-inline' https://www.paypal.com https://www.sandbox.paypal.com https://www.paypalobjects.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://www.paypal.com https://www.sandbox.paypal.com https://www.paypalobjects.com; form-action 'self' https://www.paypal.com https://www.sandbox.paypal.com mailto:; upgrade-insecure-requests;"
  # Permissions-Policy restricts device features (adjust as needed)
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # HSTS: handled by Cloudflare edge for better performance. Enable in Cloudflare dashboard with max-age=63072000, includeSubDomains, preload, then submit to https://hstspreload.org
  # Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  # Expect-CT is optional; configure report-uri or remove if not used
  # Header always set Expect-CT "max-age=86400, enforce, report-uri=\"https://example.com/report\""
</IfModule>

# --- MIME Types ---
AddType text/html .html
AddType text/plain .txt
AddType text/css .css
AddType text/javascript .js
AddType text/javascript .cjs
AddType application/json .json
AddType video/webm .webm
AddType image/webp .webp
AddType image/svg+xml .svg
AddType image/png .png
AddType image/jpeg .jpg
AddType image/jpeg .jpeg
AddType application/xml .xml
AddType image/gif .gif
AddType image/x-icon .ico
AddType text/csv .csv
AddType text/markdown .md

<FilesMatch "\.js$">
  Header set Content-Type text/javascript
</FilesMatch>

<FilesMatch "\.cjs$">
  Header set Content-Type text/javascript
</FilesMatch>

# --- Gzip Compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain application/xml text/css text/javascript application/json video/webm text/csv text/markdown
</IfModule>

# --- Production Cache Control ---
<IfModule mod_headers.c>
  # Static assets: long-lived caching (ensure cache-busting on deploys)
  <FilesMatch "\.(css|js|svg|png|jpe?g|gif|webp|ico|woff2?|ttf|webm|xml|csv|md)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML and JSON: short cache to allow content updates and revalidation
  <FilesMatch "\.(html|json)$">
    Header set Cache-Control "public, max-age=60, must-revalidate"
  </FilesMatch>

  # Cloudflare caching is best configured in the Cloudflare dashboard. Remove
  # development-specific Cloudflare bypass headers to allow proper edge caching.
</IfModule>

# --- Custom 404 Page ---
ErrorDocument 404 /404.html

# --- Clean URLs: Redirect index.html and fallback ---
RewriteEngine On
DirectoryIndex index.html

# --- Force HTTPS (handles proxies like Cloudflare) ---
# Only enable when site is served over HTTPS on all hostnames (including www)
# Checks both direct HTTPS and X-Forwarded-Proto (used by proxies/CDNs)
RewriteCond %{HTTP_HOST} !^localhost
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect /index.html to /
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Fallback to index.html for non-file requests (SPA-like)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.html [L]

# --- Disable Directory Listing ---
Options -Indexes +FollowSymLinks

# --- Crossdomain.xml and robots.txt ---
<IfModule mod_headers.c>
  <FilesMatch "^(crossdomain\.xml|robots\.txt)$">
    Header set Content-Type text/xml
  </FilesMatch>
</IfModule>

# --- Prevent access to hidden files ---
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# --- CORS for manifest.json ---
<IfModule mod_headers.c>
  <Files "manifest.json">
    Header set Access-Control-Allow-Origin "*"
  </Files>
</IfModule>

# --- CORS for static assets (CSS, images, SVG, ICO, etc) ---
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|svg|png|jpe?g|gif|ico|webp|xml)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# --- End of .htaccess ---
