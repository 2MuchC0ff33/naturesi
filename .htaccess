# Ultra-Simple  Static EStore Framework – .htaccess
# Standards: Mobile-First, Accessibility, Security

# --- Security Headers ---
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Content-Security-Policy "default-src 'self'; img-src 'self' data:; script-src 'self'; style-src 'self' 'unsafe-inline'; object-src 'self'; base-uri 'self'; form-action 'self' mailto:;"
</IfModule>

# --- MIME Types for SVG, WebP, CSS, PNG, ICO ---
AddType text/html .html
AddType image/svg+xml .svg
AddType image/webp .webp
AddType text/css .css
AddType image/png .png
AddType image/x-icon .ico

# --- Gzip Compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# --- Disable All Caching for Development ---
<IfModule mod_expires.c>
  ExpiresActive On
  # Disable caching for all file types
  ExpiresByType image/webp "access plus 0 seconds"
  ExpiresByType image/png "access plus 0 seconds"
  ExpiresByType image/svg+xml "access plus 0 seconds"
  ExpiresByType image/x-icon "access plus 0 seconds"
  ExpiresByType image/jpeg "access plus 0 seconds"
  ExpiresByType image/gif "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType application/json "access plus 0 seconds"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/plain "access plus 0 seconds"
  ExpiresByType text/xml "access plus 0 seconds"
</IfModule>

# --- Disable Cache Control Headers for All Files (Cloudflare Compatible) ---
<IfModule mod_headers.c>
  # No cache for all files to allow immediate updates
  Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
  Header set Pragma "no-cache"
  Header set Expires "0"
  
  # Cloudflare-specific headers
  Header set CF-Cache-Status "BYPASS"
  Header set CF-Cache-Control "no-cache"
  Header set CF-Cache-Tag "development"
  Header set CF-Edge-Cache "no-cache"
  Header set CF-Worker "bypass"
  
  # Additional Cloudflare bypass headers
  Header set X-CF-Cache-Status "BYPASS"
  Header set X-CF-Cache-Control "no-cache"
  Header set X-CF-Edge-Cache "no-cache"
  
  # Force Cloudflare to always fetch from origin
  Header set CF-Visitor-Origin "always"
  Header set CF-Ray-Origin "direct"
  
  # Prevent Cloudflare from caching errors
  Header set CF-Cache-Status-Error "BYPASS"
  
  # Development mode indicator
  Header set CF-Development-Mode "on"
  
  # Custom header to force cache bypass
  Header set X-Development-Cache "bypass"
</IfModule>

# --- Custom 404 Page ---
ErrorDocument 404 /404.html

# --- Clean URLs: Redirect index.html and fallback ---
RewriteEngine On
DirectoryIndex index.html

# Redirect /index.html to /
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Fallback to index.html for non-file requests (SPA-like)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.html [L]

# --- Disable Directory Listing ---
Options -Indexes +FollowSymLinks

# --- Crossdomain.xml and robots.txt ---
<IfModule mod_headers.c>
  <FilesMatch "^(crossdomain\.xml|robots\.txt)$">
    Header set Content-Type text/xml
  </FilesMatch>
</IfModule>

# --- Prevent access to hidden files ---
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# --- CORS for manifest.json ---
<IfModule mod_headers.c>
  <Files "manifest.json">
    Header set Access-Control-Allow-Origin "*"
  </Files>
</IfModule>

# --- CORS for static assets (CSS, images, SVG, ICO, etc) ---
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|svg|png|jpe?g|gif|ico|webp)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# --- End of .htaccess ---
