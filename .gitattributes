# Ensure text files use LF in the working tree and repository
# Default: treat all files as text when possible and checkout with LF
* text=auto eol=lf

# Explicitly set LF for common text file extensions and request UTF-8 working-tree encoding
*.html text eol=lf working-tree-encoding=UTF-8
*.css  text eol=lf working-tree-encoding=UTF-8
*.js   text eol=lf working-tree-encoding=UTF-8
*.json text eol=lf working-tree-encoding=UTF-8
*.md   text eol=lf working-tree-encoding=UTF-8
*.txt  text eol=lf working-tree-encoding=UTF-8
*.xml  text eol=lf working-tree-encoding=UTF-8
*.yml  text eol=lf working-tree-encoding=UTF-8
*.yaml text eol=lf working-tree-encoding=UTF-8
*.csv  text eol=lf working-tree-encoding=UTF-8

# Pages and assets (ensure HTML/JS/CSS in pages use LF/UTF-8)
pages/** text eol=lf working-tree-encoding=UTF-8
assets/** text eol=lf working-tree-encoding=UTF-8

# Images and other binary formats
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.zip binary
*.gz binary
*.7z binary

# Ensure scripts use LF
*.sh text eol=lf working-tree-encoding=UTF-8
*.ps1 text eol=lf working-tree-encoding=UTF-8
