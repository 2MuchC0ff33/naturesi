# Global attributes: auto-detect text files and enforce LF line endings
* text=auto eol=lf

# POSIX utilities / Bourne Shell (merged: added UTF-8 encoding)
*.sh text eol=lf diff=bash working-tree-encoding=UTF-8

# awk
*.awk text eol=lf

# bc
*.bc text eol=lf

# sed
*.sed text eol=lf

# JSON (merged: added UTF-8 encoding)
*.json text eol=lf working-tree-encoding=UTF-8

# HTML (merged: added UTF-8 encoding)
*.html text eol=lf diff=html working-tree-encoding=UTF-8
*.htm text eol=lf diff=html
*.xhtml text eol=lf diff=html

# Markdown (merged: added UTF-8 encoding to *.md)
*.md text eol=lf diff=markdown working-tree-encoding=UTF-8
*.markdown text eol=lf diff=markdown
*.mdwn text eol=lf diff=markdown
*.mdown text eol=lf diff=markdown
*.mkd text eol=lf diff=markdown
*.mkdn text eol=lf diff=markdown

# Javascript (merged: added UTF-8 encoding to *.js)
*.js text eol=lf working-tree-encoding=UTF-8
*.mjs text eol=lf
*.cjs text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# CSS (merged: added UTF-8 encoding)
*.css text eol=lf diff=css working-tree-encoding=UTF-8
*.scss text eol=lf diff=css
*.sass text eol=lf diff=css
*.less text eol=lf diff=css
*.styl text eol=lf diff=css

# dotenv
*.env text eol=lf

# C99
*.c text eol=lf diff=cpp
*.h text eol=lf diff=cpp

# Fort77
*.f text eol=lf diff=fortran
*.for text eol=lf diff=fortran
*.f77 text eol=lf diff=fortran

# Lex
*.l text eol=lf diff=cpp
*.lex text eol=lf diff=cpp

# Assembly
*.s text eol=lf
*.asm text eol=lf

# CSV (merged: added UTF-8 encoding)
*.csv text eol=lf working-tree-encoding=UTF-8

# m4
*.m4 text eol=lf

# yacc
*.y text eol=lf diff=cpp
*.yacc text eol=lf diff=cpp

# XML (merged: added UTF-8 encoding)
*.xml text eol=lf working-tree-encoding=UTF-8

# Additional text files (from user's version)
*.txt text eol=lf working-tree-encoding=UTF-8
*.yml text eol=lf working-tree-encoding=UTF-8
*.yaml text eol=lf working-tree-encoding=UTF-8

# Pages and assets (from user's version)
pages/** text eol=lf working-tree-encoding=UTF-8
assets/** text eol=lf working-tree-encoding=UTF-8

# Images and other binary formats (from user's version)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.zip binary
*.gz binary
*.7z binary
