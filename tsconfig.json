{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "types": ["vitest/globals", "node", "@playwright/test"]
  },
  "include": ["tests/**/*.ts", "assets/js/modules/**/*.js"]
}
