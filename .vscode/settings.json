{
  "harper.markdown.IgnoreLinkTitle": true,
  "editor.rulers": [
    80
  ],
  "editor.wordWrap": "wordWrapColumn",
  "editor.wordWrapColumn": 80,
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/.vscode": false
  },
  // machine-specific terminal profiles should live in a local
  // override file (see README). kept here only so the JSON stays valid
  "terminal.integrated.profiles.windows": {},
  "postcssense.cssPath": "./node_modules/postcss",
  "intelephense.environment.phpVersion": "8.1.28"
}
