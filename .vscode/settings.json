{
  "harper.markdown.IgnoreLinkTitle": true,
  "editor.rulers": [
    80
  ],
  "editor.wordWrap": "wordWrapColumn",
  "editor.wordWrapColumn": 80,
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/.vscode": false
  },
  "terminal.integrated.profiles.windows": {
    "Cygwin": {
      "path": "C:\\Users\\galloa\\scoop\\persist\\cygwin\\root\\bin\\sh.exe",
      "args": [
        "-l",
        "-i"
      ],
      "env": {
        "CHERE_INVOKING": "1"
      },
      "cwd": "${workspaceFolder}"
    }
  },
  "postcssense.cssPath": "./node_modules/postcss"
}
