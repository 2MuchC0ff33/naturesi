{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start-httpd",
      "type": "process",
      "command": "C:\\Users\\galloa\\scoop\\shims\\cygwin.exe",
      "args": [
        "-i",
        "-c",
        "apachectl start"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "stop-httpd",
      "type": "process",
      "command": "C:\\Users\\galloa\\scoop\\shims\\cygwin.exe",
      "args": [
        "-i",
        "-c",
        "apachectl stop"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "wait-for-httpd",
      "type": "process",
      "command": "node",
      "args": [
        "${workspaceFolder}/scripts/wait-for-port.cjs",
        "8000",
        "30"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "dev-httpd",
      "dependsOn": [
        "start-httpd",
        "wait-for-httpd"
      ],
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
