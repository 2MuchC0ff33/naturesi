[
  {
    "key": "ctrl+shift+l",
    "command": "workbench.action.tasks.runTask",
    "args": "lint-current-file-biome",
    "when": "resourceExtname =~ /\\.(js|ts)$/"
  },
  {
    "key": "ctrl+shift+l",
    "command": "workbench.action.tasks.runTask",
    "args": "lint-current-file-html",
    "when": "resourceExtname == .html"
  }
]
