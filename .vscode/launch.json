{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Open with Live Server",
      "url": "http://localhost:5500",
      "webRoot": "${workspaceFolder}"
    },
    {
      "type": "bash",
      "request": "launch",
      "name": "Cygwin Script",
      "program": "C:/Users/galloa/scoop/apps/cygwin/current/bin/bash.exe",
      "args": ["${file}"],
      "windows": {
        "program": "C:/Users/galloa/scoop/apps/cygwin/current/bin/bash.exe"
      }
    },
    {
      "name": "Debug Vitest - Current File",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "--", "${file}"],
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "test",
        "TEST_CHROME_PATH": "C:\\\Program Files\\\\Google\\\\Chrome\\\\Application\\\\chrome.exe"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Playwright Test (Chromium)",
      "type": "pwa-node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/@playwright/test/lib/cli.js",
      "args": ["test", "--project=chromium", "--debug"],
      "env": {
        "TEST_CHROME_PATH": "C:\\\Program Files\\\\Google\\\\Chrome\\\\Application\\\\chrome.exe"
      },
      "console": "integratedTerminal",
      "runtimeExecutable": "C:\\\Windows\\\\System32\\\\bash.exe",
      "runtimeArgs": ["-lc"]
    }
  ]
}
