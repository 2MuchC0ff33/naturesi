{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Open with Live Server",
      "url": "http://localhost:5500",
      "webRoot": "${workspaceFolder}"
    },
    {
      "type": "bash",
      "request": "launch",
      "name": "Cygwin Script",
      "program": "C:/Users/galloa/scoop/apps/cygwin/current/bin/bash.exe",
      "args": ["${file}"],
      "windows": {
        "program": "C:/Users/galloa/scoop/apps/cygwin/current/bin/bash.exe"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Node Tests (current file)",
      "program": "${workspaceFolder}/node_modules/.bin/node",
      "args": ["--test", "${file}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug All Tests",
      "program": "${workspaceFolder}/node_modules/.bin/node",
      "args": ["--test", "tests"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Start server then run tests (compound)",
      "configurations": ["Debug All Tests"],
      "preLaunchTask": "Serve (local)"
    }
  ]
}
